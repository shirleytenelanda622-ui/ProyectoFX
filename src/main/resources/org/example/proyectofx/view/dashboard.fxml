<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="contenedorPrincipal"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.proyectofx.controller.DashboardController"
            styleClass="root-dashboard">


    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="15"
              styleClass="barra-superior">

            <padding>
                <Insets top="12" right="20" bottom="12" left="20"/>
            </padding>

            <ImageView fitHeight="40"
                       fitWidth="40"
                       preserveRatio="true">
                <Image url="@../Imagenes/login.png"/>
            </ImageView>

            <VBox spacing="2">

                <Label text="Sistema Veterinaria"
                       styleClass="titulo-app"/>

                <Label text="Sistema de Gestión"
                       styleClass="subtitulo-app"/>

            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox alignment="CENTER_RIGHT"
                  spacing="2">

                <Label fx:id="lblNombreUsuario"
                       text="Usuario"
                       styleClass="usuario-nombre"/>

                <Label fx:id="lblRolUsuario"
                       text="Administrador"
                       styleClass="usuario-rol"/>

            </VBox>

            <Button fx:id="btnCerrarSesion"
                    text="Cerrar sesión"
                    onAction="#onCerrarSesion"
                    styleClass="boton-secundario"/>

        </HBox>
    </top>


    <left>

        <VBox spacing="15"
              prefWidth="220"
              styleClass="menu-lateral">

            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <Label text="MENÚ"
                   styleClass="titulo-menu"/>

            <Separator/>

            <Button fx:id="btnMascotas"
                    text="🐶 Mascotas"
                    maxWidth="Infinity"
                    prefHeight="42"
                    onAction="#onMascotas"
                    styleClass="boton-menu"/>

            <Button fx:id="btnPropietarios"
                    text="👤 Propietarios"
                    maxWidth="Infinity"
                    prefHeight="42"
                    onAction="#onPropietarios"
                    styleClass="boton-menu"/>

            <Button fx:id="btnUsuarios"
                    text="👥 Usuarios"
                    maxWidth="Infinity"
                    prefHeight="42"
                    onAction="#onUsuarios"
                    styleClass="boton-menu"/>

            <Button fx:id="btnReportes"
                    text="📊 Reportes"
                    maxWidth="Infinity"
                    prefHeight="42"
                    onAction="#onReportes"
                    styleClass="boton-menu"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Separator/>

            <Label text="Programación Orientada a Objetos"
                   wrapText="true"
                   styleClass="texto-footer"/>

        </VBox>

    </left>

    <center>

        <StackPane styleClass="panel-contenido">

            <Label text="Seleccione una opción del menú"
                   styleClass="placeholder-label"/>

        </StackPane>

    </center>

</BorderPane>