<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.proyectofx.controller.PropietariosController"
      spacing="18"
      styleClass="contenido-modulo">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Gestión de Propietarios"
           styleClass="titulo-modulo"/>


    <TitledPane text="Datos del propietario"
                expanded="true"
                collapsible="false">

        <content>

            <GridPane hgap="15"
                      vgap="12">

                <columnConstraints>
                    <ColumnConstraints percentWidth="33"/>
                    <ColumnConstraints percentWidth="33"/>
                    <ColumnConstraints percentWidth="34"/>
                </columnConstraints>


                <VBox spacing="5"
                      GridPane.columnIndex="0"
                      GridPane.rowIndex="0">

                    <Label text="Cédula"/>

                    <TextField fx:id="txtCedula"
                               promptText="Ingrese la cédula"
                               styleClass="campo-texto"/>

                </VBox>

                <VBox spacing="5"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="0">

                    <Label text="Nombre completo"/>

                    <TextField fx:id="txtNombre"
                               promptText="Nombre del propietario"
                               styleClass="campo-texto"/>

                </VBox>

                <VBox spacing="5"
                      GridPane.columnIndex="2"
                      GridPane.rowIndex="0">

                    <Label text="Teléfono"/>

                    <TextField fx:id="txtTelefono"
                               promptText="Número telefónico"
                               styleClass="campo-texto"/>

                </VBox>


                <VBox spacing="5"
                      GridPane.columnIndex="0"
                      GridPane.columnSpan="2"
                      GridPane.rowIndex="1">

                    <Label text="Dirección"/>

                    <TextField fx:id="txtDireccion"
                               promptText="Dirección"
                               styleClass="campo-texto"/>

                </VBox>

                <VBox spacing="5"
                      GridPane.columnIndex="2"
                      GridPane.rowIndex="1">

                    <Label text="Correo electrónico"/>

                    <TextField fx:id="txtCorreo"
                               promptText="correo@ejemplo.com"
                               styleClass="campo-texto"/>

                </VBox>

            </GridPane>

        </content>

    </TitledPane>


    <HBox spacing="12"
          alignment="CENTER_LEFT">

        <Button fx:id="guardar"
                text="Guardar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onGuardar"
                styleClass="boton-primario"/>

        <Button fx:id="editar"
                text="Editar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onActualizar"
                styleClass="boton-secundario"/>

        <Button fx:id="eliminar"
                text="Eliminar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onEliminar"
                styleClass="boton-peligro"/>

        <Button fx:id="limpiar"
                text="Limpiar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onLimpiar"
                styleClass="boton-secundario"/>

    </HBox>


    <TitledPane text="Listado de propietarios"
                expanded="true"
                collapsible="false"
                VBox.vgrow="ALWAYS">

        <content>

            <TableView fx:id="tablaPropietarios">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"/>

                    <TableColumn fx:id="colCedula"
                                 text="Cédula"/>

                    <TableColumn fx:id="colNombre"
                                 text="Nombre"/>

                    <TableColumn fx:id="colTelefono"
                                 text="Teléfono"/>

                    <TableColumn fx:id="colDireccion"
                                 text="Dirección"/>

                    <TableColumn fx:id="colCorreo"
                                 text="Correo"/>

                </columns>

            </TableView>

        </content>

    </TitledPane>

</VBox>