<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.proyectofx.controller.UsuariosController"
      spacing="18"
      styleClass="contenido-modulo">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- TÍTULO -->

    <Label text="Gestión de Usuarios"
           styleClass="titulo-modulo"/>

    <!-- DATOS -->

    <TitledPane text="Datos del usuario"
                expanded="true"
                collapsible="false">

        <content>

            <GridPane hgap="15"
                      vgap="12">

                <columnConstraints>

                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>

                </columnConstraints>

                <!-- NOMBRE -->

                <VBox spacing="5"
                      GridPane.columnIndex="0"
                      GridPane.rowIndex="0">

                    <Label text="Nombre completo"/>

                    <TextField fx:id="txtNombre"
                               promptText="Ingrese el nombre"
                               styleClass="campo-texto"/>

                </VBox>

                <!-- CORREO -->

                <VBox spacing="5"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="0">

                    <Label text="Correo electrónico"/>

                    <TextField fx:id="txtCorreo"
                               promptText="correo@ejemplo.com"
                               styleClass="campo-texto"/>

                </VBox>

                <!-- CONTRASEÑA -->

                <VBox spacing="5"
                      GridPane.columnIndex="2"
                      GridPane.rowIndex="0">

                    <Label text="Contraseña"/>

                    <PasswordField fx:id="txtContrasena"
                                   promptText="Mínimo 6 caracteres"
                                   styleClass="campo-texto"/>

                </VBox>

                <!-- ROL -->

                <VBox spacing="5"
                      GridPane.columnIndex="3"
                      GridPane.rowIndex="0">

                    <Label text="Rol"/>

                    <ComboBox fx:id="cbRol"
                              promptText="Seleccione"
                              maxWidth="Infinity"/>

                </VBox>

            </GridPane>

        </content>

    </TitledPane>

    <!-- BOTONES -->

    <HBox spacing="12"
          alignment="CENTER_LEFT">

        <Button fx:id="crear"
                text="Crear usuario"
                prefWidth="140"
                prefHeight="40"
                onAction="#onGuardar"
                styleClass="boton-primario"/>

        <Button fx:id="limpiar"
                text="Limpiar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onLimpiar"
                styleClass="boton-secundario"/>

    </HBox>

    <!-- TABLA -->

    <TitledPane text="Usuarios registrados"
                expanded="true"
                collapsible="false"
                VBox.vgrow="ALWAYS">

        <content>

            <TableView fx:id="tablaUsuarios">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"/>

                    <TableColumn fx:id="colNombre"
                                 text="Nombre"/>

                    <TableColumn fx:id="colCorreo"
                                 text="Correo"/>

                    <TableColumn fx:id="colRol"
                                 text="Rol"/>

                </columns>

            </TableView>

        </content>

    </TitledPane>

</VBox>