<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="contenedor" alignment="CENTER" spacing="14.0" styleClass="root-login" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofx.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <ImageView fitHeight="70.0" fitWidth="70.0" preserveRatio="true">
        <Image url="@../images/logo.png" />
    </ImageView>

    <Label styleClass="titulo-login" text="Sistema Veterinaria" />
    <Label styleClass="subtitulo-login" text="Ingrese sus credenciales" />

    <TextField fx:id="txtCorreo" promptText="Correo electrónico" styleClass="campo-texto" />
    <PasswordField fx:id="txtContrasena" promptText="Contraseña" styleClass="campo-texto" />

    <Button fx:id="Ingresar" defaultButton="true" onAction="#Ingresar" styleClass="boton-primario" text="Ingresar" />

    <Label fx:id="lblMensaje" styleClass="mensaje-error" />
</VBox>
