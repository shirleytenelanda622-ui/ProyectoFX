<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="contenedor" alignment="CENTER" prefWidth="300.0" spacing="14.0" styleClass="root-login" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofx.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <ImageView fitHeight="101.0" fitWidth="125.0" preserveRatio="true">
        <Image url="@../Imagenes/logo.png" />
      <VBox.margin>
         <Insets bottom="10.0" />
      </VBox.margin>
    </ImageView>

    <Label fx:id="titulo" styleClass="titulo-login" text="Sistema Veterinaria">
      <VBox.margin>
         <Insets bottom="15.0" />
      </VBox.margin></Label>
    <Label fx:id="text" styleClass="subtitulo-login" text="Ingrese sus credenciales">
      <VBox.margin>
         <Insets bottom="10.0" />
      </VBox.margin></Label>
   <Label fx:id="correo" text="Correo:">
      <VBox.margin>
         <Insets bottom="10.0" top="10.0" />
      </VBox.margin>
   </Label>



    <TextField fx:id="txtCorreo" promptText="Correo electrónico" styleClass="campo-texto" />
   <Label fx:id="pass" text="Contraseña:">
      <VBox.margin>
         <Insets bottom="10.0" top="10.0" />
      </VBox.margin>
   </Label>
    <PasswordField fx:id="txtContrasena" promptText="Contraseña" styleClass="campo-texto" />

    <Button fx:id="Ingresar" defaultButton="true" onAction="#Ingresar" prefHeight="40.0" prefWidth="150.0" styleClass="boton-primario" text="Ingresar" />

    <Label fx:id="lblMensaje" styleClass="mensaje-error" />
</VBox>
