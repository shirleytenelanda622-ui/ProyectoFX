<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.proyectofx.controller.MascotasController"
      spacing="18"
      styleClass="contenido-modulo">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Gestión de Mascotas"
           styleClass="titulo-modulo"/>


    <TitledPane text="Datos de la mascota"
                expanded="true"
                collapsible="false">

        <content>

            <GridPane hgap="15"
                      vgap="12">

                <columnConstraints>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                    <ColumnConstraints percentWidth="25"/>
                </columnConstraints>


                <VBox spacing="5"
                      GridPane.columnIndex="0"
                      GridPane.rowIndex="0">

                    <Label text="Nombre"/>

                    <TextField fx:id="txtNombre"
                               promptText="Nombre de la mascota"
                               styleClass="campo-texto"/>

                </VBox>

                <VBox spacing="5"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="0">

                    <Label text="Especie"/>

                    <TextField fx:id="txtEspecie"
                               promptText="Perro, gato..."
                               styleClass="campo-texto"/>

                </VBox>

                <VBox spacing="5"
                      GridPane.columnIndex="2"
                      GridPane.rowIndex="0">

                    <Label text="Raza"/>

                    <TextField fx:id="txtRaza"
                               promptText="Raza"
                               styleClass="campo-texto"/>

                </VBox>

                <VBox spacing="5"
                      GridPane.columnIndex="3"
                      GridPane.rowIndex="0">

                    <Label text="Sexo"/>

                    <ComboBox fx:id="cbSexo"
                              promptText="Seleccione"
                              maxWidth="Infinity"/>

                </VBox>


                <VBox spacing="5"
                      GridPane.columnIndex="0"
                      GridPane.rowIndex="1">

                    <Label text="Edad"/>

                    <TextField fx:id="txtEdad"
                               promptText="Años"
                               styleClass="campo-texto"/>

                </VBox>

                <VBox spacing="5"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="1">

                    <Label text="Peso"/>

                    <TextField fx:id="txtPeso"
                               promptText="Kg"
                               styleClass="campo-texto"/>

                </VBox>

                <VBox spacing="5"
                      GridPane.columnIndex="2"
                      GridPane.columnSpan="2"
                      GridPane.rowIndex="1">

                    <Label text="Propietario"/>

                    <ComboBox fx:id="cbPropietario"
                              promptText="Seleccione un propietario"
                              maxWidth="Infinity"/>

                </VBox>

            </GridPane>

        </content>

    </TitledPane>


    <HBox alignment="CENTER_LEFT"
          spacing="12">

        <Button fx:id="guardar"
                text="Guardar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onGuardar"
                styleClass="boton-primario"/>

        <Button fx:id="editar"
                text="Editar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onActualizar"
                styleClass="boton-secundario"/>

        <Button fx:id="eliminar"
                text="Eliminar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onEliminar"
                styleClass="boton-peligro"/>

        <Button fx:id="limpiar"
                text="Limpiar"
                prefWidth="120"
                prefHeight="40"
                onAction="#onLimpiar"
                styleClass="boton-secundario"/>

    </HBox>


    <TitledPane text="Listado de mascotas"
                expanded="true"
                collapsible="false"
                VBox.vgrow="ALWAYS">

        <content>

            <TableView fx:id="tablaMascotas">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID"/>

                    <TableColumn fx:id="colNombre"
                                 text="Nombre"/>

                    <TableColumn fx:id="colEspecie"
                                 text="Especie"/>

                    <TableColumn fx:id="colRaza"
                                 text="Raza"/>

                    <TableColumn fx:id="colEdad"
                                 text="Edad"/>

                    <TableColumn fx:id="colSexo"
                                 text="Sexo"/>

                    <TableColumn fx:id="colPeso"
                                 text="Peso"/>

                    <TableColumn fx:id="colPropietario"
                                 text="Propietario"/>

                </columns>

            </TableView>

        </content>

    </TitledPane>

</VBox>