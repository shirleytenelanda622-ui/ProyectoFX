<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="16.0" styleClass="contenido-modulo" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyectofx.controller.MascotasController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label styleClass="titulo-modulo" text="Gestión de Mascotas" />

    <GridPane hgap="12.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
            <ColumnConstraints percentWidth="25" />
        </columnConstraints>


        <TextField fx:id="txtNombre" promptText="Nombre mascota" styleClass="campo-texto" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtEspecie" promptText="Especie" styleClass="campo-texto" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <TextField fx:id="txtRaza" promptText="Raza" styleClass="campo-texto" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <ComboBox fx:id="cbSexo" maxWidth="Infinity" promptText="Sexo" GridPane.columnIndex="3" GridPane.rowIndex="0" />

        <TextField fx:id="txtEdad" promptText="Edad (años)" styleClass="campo-texto" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtPeso" promptText="Peso (kg)" styleClass="campo-texto" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <ComboBox fx:id="cbPropietario" maxWidth="Infinity" promptText="Propietario" GridPane.columnIndex="2" GridPane.columnSpan="2" GridPane.rowIndex="1" />
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <HBox spacing="10.0">
        <Button fx:id="guardar" onAction="#onGuardar" styleClass="boton-primario" text="Guardar" />
        <Button fx:id="editar" onAction="#onActualizar" styleClass="boton-secundario" text="Editar" />
        <Button fx:id="eliminar" onAction="#onEliminar" styleClass="boton-peligro" text="Eliminar" />
        <Button fx:id="limpiar" onAction="#onLimpiar" styleClass="boton-secundario" text="Limpiar" />
    </HBox>

    <TableView fx:id="tablaMascotas" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre" />
            <TableColumn fx:id="colEspecie" prefWidth="100.0" text="Especie" />
            <TableColumn fx:id="colRaza" prefWidth="100.0" text="Raza" />
            <TableColumn fx:id="colEdad" prefWidth="70.0" text="Edad" />
            <TableColumn fx:id="colSexo" prefWidth="80.0" text="Sexo" />
            <TableColumn fx:id="colPeso" prefWidth="80.0" text="Peso" />
            <TableColumn fx:id="colPropietario" prefWidth="150.0" text="Propietario" />
        </columns>
    </TableView>
</VBox>
